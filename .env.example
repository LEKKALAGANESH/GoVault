# ===========================================
# GoVault - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ===========================================

# --- Supabase (Required) ---
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (server-side only, never expose to client)
# Used for admin operations that bypass Row Level Security
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# --- OpenRouter AI (Required for AI Agent features) ---
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# --- Unsplash (Optional - for trip cover images) ---
# Get your key from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# --- App URL (Optional - defaults to https://govault.app) ---
# Used as HTTP-Referer header for OpenRouter requests
NEXT_PUBLIC_APP_URL=http://localhost:3000
